{
  "manifest_version": 3,
  "name": "CopyTitle",
  "version": "1.3.0",
  "description": "Extension pour copier l'URL et le titre de la page active au format MD + HTML",
  "action": {
    "default_popup": "popup.html",
    "default_title": "CopyTitle",
    "default_icon": {
      "512": "icons/icon512.png"
    }
  },
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "storage"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+C"
      },
      "description": "Ouvre la popup CopyTitle"
    }
  },
  "icons": {
    "512": "icons/icon512.png",
    "128": "icons/icon128.png"
  }
}